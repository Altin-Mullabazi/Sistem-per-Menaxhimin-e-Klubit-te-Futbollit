{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FootballClubDB;Trusted_Connection=true;Encrypt=false"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-change-this-in-production-256-bits-minimum",
    "Issuer": "FootballClubAPI",
    "Audience": "FootballClubApp",
    "ExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "CORS": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  }
}
